# Sinbad Core v0.1 — environment variables
# Copy to .env and fill in. Never commit real secrets.

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=

# Service role key — backend only. Bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# v0.1 endpoint protection. Callers of observe-identity must send this exact
# value in the X-Sinbad-Core-Secret header. Use a long random string. Keep secret.
SINBAD_CORE_SECRET=

# Shopify webhook signing secret. Used by shopify-customer-webhook to verify
# the X-Shopify-Hmac-Sha256 signature. Source: Shopify (app/webhook signing
# secret). Keep secret.
SHOPIFY_WEBHOOK_SECRET=

# Shopify OAuth / Admin API integration. Used for the Sinbad-managed app
# authorization-code connection and draft-only product creation.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_ADMIN_API_VERSION=2026-04
SHOPIFY_OAUTH_REDIRECT_URI=
SHOPIFY_OAUTH_TOKEN_ENCRYPTION_KEY=
SHOPIFY_PRODUCT_PUBLISH_ENABLED=false
SHOPIFY_PUBLISH_MODE=draft_only
